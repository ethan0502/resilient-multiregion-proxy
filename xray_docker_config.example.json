          "xver": 0,
          "serverNames": [
            "example-cdn.com"
          ],
          "privateKey": "<REALITY_PRIVATE_KEY>",
          "shortIds": [
            "<SHORT_ID_1>",
            "<SHORT_ID_2>",
            "<SHORT_ID_3>",
            "<SHORT_ID_4>",
            "<SHORT_ID_5>"
          ]
        }
      }
    }
  ],
  "outbounds": [
